# Copia este archivo como .env y reemplaza los ejemplos con credenciales de prueba.
# No confirmes .env en Git.
POSTGRES_PASSWORD=replace_with_postgresql_password

PAYPAL_CLIENT_ID=replace_with_sandbox_client_id
PAYPAL_CLIENT_SECRET=replace_with_sandbox_client_secret
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com
PAYPAL_RETURN_URL=http://localhost:5164/Payment/Success
PAYPAL_CANCEL_URL=http://localhost:5164/Payment/Cancel
PAYPAL_CURRENCY_CODE=USD

PAYPHONE_TOKEN=replace_with_test_token
PAYPHONE_STORE_ID=replace_with_test_store_id
