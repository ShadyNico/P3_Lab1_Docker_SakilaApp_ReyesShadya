@model IEnumerable<SakilaApp.Models.Category>

@{
    ViewData["Title"] = "Categories";
    var canCreateOrEdit = User.IsInRole("Administrador") || User.IsInRole("Supervisor");
    var canDelete = User.IsInRole("Administrador");
}

<div class="page-header">
    <h1>Categories</h1>
    @if (canCreateOrEdit)
    {
        <a asp-action="Create" class="btn btn-primary">Create New</a>
    }
</div>

<div class="table-responsive app-table">
<table class="table table-hover align-middle">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Name)
            </th>
            <th class="d-none d-md-table-cell">
                @Html.DisplayNameFor(model => model.LastUpdate)
            </th>
            <th class="table-actions-cell">Actions</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td class="d-none d-md-table-cell">
                @Html.DisplayFor(modelItem => item.LastUpdate)
            </td>
            <td class="table-actions-cell">
                <div class="table-actions">
                @if (canCreateOrEdit)
                {
                    <a asp-action="Edit" asp-route-id="@item.CategoryId" class="btn btn-sm btn-outline-primary">Edit</a>
                }
                <a asp-action="Details" asp-route-id="@item.CategoryId" class="btn btn-sm btn-outline-secondary">Details</a>
                @if (canDelete)
                {
                    <a asp-action="Delete" asp-route-id="@item.CategoryId" class="btn btn-sm btn-outline-danger">Delete</a>
                }
                </div>
            </td>
        </tr>
}
    </tbody>
</table>
</div>

<partial name="_Pagination" />
