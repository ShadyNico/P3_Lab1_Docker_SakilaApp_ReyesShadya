@model IEnumerable<SakilaApp.Models.Commerce.FilmStock>

<h1>Inventario de películas</h1>

<a class="btn btn-primary" asp-action="Inicializar">Inicializar inventario desde Sakila</a>

<table class="table table-striped mt-3">
    <thead>
        <tr>
            <th>Película</th>
            <th>Precio</th>
            <th>Stock</th>
            <th>Agregar stock</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Title</td>
            <td>@item.UnitPrice.ToString("C")</td>
            <td>@item.Stock</td>
            <td>
                <form asp-action="AumentarStock" method="post" class="d-flex gap-2">
                    <input type="hidden" name="id" value="@item.FilmStockId" />
                    <input type="number" name="cantidad" value="1" min="1" class="form-control" style="width:90px" />
                    <button class="btn btn-success">Aumentar</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>