@model SakilaApp.Models.Commerce.PaymentTransaction

<h1>Pago generado</h1>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<p><strong>Orden:</strong> @Model.PurchaseOrderId</p>
<p><strong>Pasarela:</strong> @Model.Provider</p>
<p><strong>Estado:</strong> @Model.Status</p>
<p><strong>Total:</strong> @((Model.AmountInCents / 100m).ToString("C"))</p>
<p><strong>Transaccion cliente:</strong> @Model.ClientTransactionId</p>

@if (Model.Provider == "PayPhone" && !string.IsNullOrWhiteSpace(Model.PayphonePaymentUrl))
{
    <a class="btn btn-success" href="@Model.PayphonePaymentUrl" target="_blank">
        Abrir link de pago PayPhone
    </a>
}

@if (Model.Provider == "PayPal" && Model.Status == "Pending" && !string.IsNullOrWhiteSpace(Model.PayPalApprovalUrl))
{
    <a class="btn btn-info" href="@Model.PayPalApprovalUrl" target="_blank">
        Abrir PayPal Sandbox
    </a>
}

@if (Model.Status == "Paid")
{
    <div class="alert alert-success mt-3">
        Pago confirmado correctamente.
    </div>
}

@if (Model.Status == "Cancelled")
{
    <div class="alert alert-warning mt-3">
        Pago cancelado.
    </div>
}

@if (Model.Status == "Failed")
{
    <div class="alert alert-danger mt-3">
        No se pudo generar o confirmar el pago.
    </div>
}

@if (!string.IsNullOrWhiteSpace(Model.PayPalOrderId))
{
    <p class="mt-3"><strong>Orden PayPal:</strong> @Model.PayPalOrderId</p>
}

@if (!string.IsNullOrWhiteSpace(Model.PayPalCaptureId))
{
    <p><strong>Captura PayPal:</strong> @Model.PayPalCaptureId</p>
}

@if (User.IsInRole("Administrador") && Model.Status == "Pending")
{
    <a class="btn btn-warning" asp-action="MarkAsPaid" asp-route-id="@Model.PaymentTransactionId">
        Marcar como pagado para demostracion
    </a>
}

<h2>Detalle de la orden</h2>
<table class="table table-bordered">
    <thead>
        <tr>
            <th>Pelicula</th>
            <th>Cantidad</th>
            <th>Precio</th>
            <th>Subtotal</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var d in Model.PurchaseOrder.Details)
    {
        <tr>
            <td>@d.FilmTitle</td>
            <td>@d.Quantity</td>
            <td>@d.UnitPrice.ToString("C")</td>
            <td>@d.Subtotal.ToString("C")</td>
        </tr>
    }
    </tbody>
</table>
