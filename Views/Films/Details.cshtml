@model SakilaApp.Models.Film

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Film</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Title)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Title)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.ReleaseYear)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.ReleaseYear)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.RentalDuration)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.RentalDuration)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.RentalRate)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.RentalRate)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Length)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Length)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.ReplacementCost)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.ReplacementCost)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.LastUpdate)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.LastUpdate)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.SpecialFeatures)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.SpecialFeatures)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Fulltext)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Fulltext)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Language)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Language.LanguageId)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.OriginalLanguage)
        </dt>
        <dd class = "col-sm-10">
            @* ANTES: @Html.DisplayFor(model => model.OriginalLanguage.LanguageId) *@
            @* CORREGIDO: se usa ?. para no fallar cuando OriginalLanguage es null. *@
            @(Model.OriginalLanguage?.LanguageId.ToString() ?? "Sin idioma original")
        </dd>
    </dl>
</div>
<div class="d-flex flex-wrap gap-2">
    @if (User.IsInRole("Administrador") || User.IsInRole("Supervisor"))
    {
        <a asp-action="Edit" asp-route-id="@Model?.FilmId" class="btn btn-primary">Edit</a>
    }
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>
