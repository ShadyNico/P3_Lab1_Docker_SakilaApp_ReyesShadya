@model IEnumerable<SakilaApp.Models.Film>

@* ANTES: ViewData["Title"] = "Index"; y el encabezado decia Index. *@
@* CORREGIDO: ahora el titulo y encabezado dicen Films. *@
@{
    ViewData["Title"] = "Films";
    var canCreateOrEdit = User.IsInRole("Administrador") || User.IsInRole("Supervisor");
    var canDelete = User.IsInRole("Administrador");
}

<div class="page-header">
    <h1>Films</h1>
    @if (canCreateOrEdit)
    {
        <a asp-action="Create" class="btn btn-primary">Create New</a>
    }
</div>

<form asp-action="Index" method="get" class="filter-bar">
    <div class="row g-2">
        <div class="col-md-5">
            <input type="text" name="buscar" value="@ViewBag.Buscar"
                   class="form-control"
                   placeholder="Buscar por título" />
        </div>

        <div class="col-md-3">
            <input type="number" name="duracionMinima" value="@ViewBag.DuracionMinima"
                   class="form-control"
                   placeholder="Duración mínima" />
        </div>

        <div class="col-md-4">
            <button type="submit" class="btn btn-primary">Filtrar</button>
            <a asp-action="Index" class="btn btn-secondary">Limpiar</a>
        </div>
    </div>
</form>

<div class="table-responsive app-table">
<table class="table table-hover align-middle">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Title)
            </th>
            <th class="d-none d-xl-table-cell">
                @Html.DisplayNameFor(model => model.Description)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ReleaseYear)
            </th>
            <th class="d-none d-lg-table-cell">
                @Html.DisplayNameFor(model => model.RentalDuration)
            </th>
            <th class="d-none d-xl-table-cell">
                @Html.DisplayNameFor(model => model.RentalRate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Length)
            </th>
            <th class="d-none d-xl-table-cell">
                @Html.DisplayNameFor(model => model.ReplacementCost)
            </th>
            <th class="d-none d-xxl-table-cell">
                @Html.DisplayNameFor(model => model.LastUpdate)
            </th>
            <th class="d-none d-xxl-table-cell">
                @Html.DisplayNameFor(model => model.SpecialFeatures)
            </th>
            <th class="d-none d-xxl-table-cell">
                @Html.DisplayNameFor(model => model.Fulltext)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Language)
            </th>
            <th class="d-none d-xl-table-cell">
                @Html.DisplayNameFor(model => model.OriginalLanguage)
            </th>
            <th class="table-actions-cell">Actions</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Title)
            </td>
            <td class="d-none d-xl-table-cell">
                @Html.DisplayFor(modelItem => item.Description)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ReleaseYear)
            </td>
            <td class="d-none d-lg-table-cell">
                @Html.DisplayFor(modelItem => item.RentalDuration)
            </td>
            <td class="d-none d-xl-table-cell">
                @Html.DisplayFor(modelItem => item.RentalRate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Length)
            </td>
            <td class="d-none d-xl-table-cell">
                @Html.DisplayFor(modelItem => item.ReplacementCost)
            </td>
            <td class="d-none d-xxl-table-cell">
                @Html.DisplayFor(modelItem => item.LastUpdate)
            </td>
            <td class="d-none d-xxl-table-cell">
                @Html.DisplayFor(modelItem => item.SpecialFeatures)
            </td>
            <td class="d-none d-xxl-table-cell">
                @Html.DisplayFor(modelItem => item.Fulltext)
            </td>
            <td>
                @(item.Language?.Name ?? "Sin idioma")
            </td>
            <td class="d-none d-xl-table-cell">
                @(item.OriginalLanguage?.Name ?? "Sin idioma original")
            </td>
            <td class="table-actions-cell">
                <div class="table-actions">
                @if (canCreateOrEdit)
                {
                    <a asp-action="Edit" asp-route-id="@item.FilmId" class="btn btn-sm btn-outline-primary">Edit</a>
                }
                <a asp-action="Details" asp-route-id="@item.FilmId" class="btn btn-sm btn-outline-secondary">Details</a>
                @if (canDelete)
                {
                    <a asp-action="Delete" asp-route-id="@item.FilmId" class="btn btn-sm btn-outline-danger">Delete</a>
                }
                </div>
            </td>
        </tr>
}
    </tbody>
</table>
</div>

<partial name="_Pagination" />
